# This file contains the fastlane.tools configuration
# You can find the documentation at https://docs.fastlane.tools
#
# For a list of all available actions, check out
#
#     https://docs.fastlane.tools/actions
#
# For a list of all available plugins, check out
#
#     https://docs.fastlane.tools/plugins/available-plugins
#

# Uncomment the line if you want fastlane to automatically update itself
# update_fastlane

default_platform(:ios)

platform :ios do
  lane :beta do
    setup_ci if ENV['CI']
    match(type: 'appstore')
    api_key = app_store_connect_api_key(
      key_id: ENV['ASC_API_ID'],
      issuer_id: ENV['ASC_ISSUER_ID'],
      key_content: ENV['ASC_API_KEY'],
      duration: 1200, # optional (maximum 1200)
      in_house: false # optional but may be required if using match/sigh
    )
    # increment_version_number(
    #   version_number: ENV['VERSION_NUMBER'],
    #   xcodeproj: "./Django Files.xcodeproj"
    # )
    # Extract base version number without any -123 style additions
    base_version = ENV['VERSION_NUMBER'].split('-').first
    sh("sed -i '' 's/MARKETING_VERSION = [0-9]*\.[0-9]*\.[0-9]*/MARKETING_VERSION = #{base_version};/' \"../Django Files.xcodeproj/project.pbxproj\"")
    increment_build_number(
      build_number: ENV['BUILD_NUMBER'],
      xcodeproj: "./Django Files.xcodeproj"
    )
    build_app()
    pilot(skip_submission: true)
    # upload_to_testflight(skip_waiting_for_build_processing: true, username: ENV['APPLE_ID'])
  end

  lane :push_appstore do
    setup_ci if ENV['CI']
    match(type: 'appstore')
    api_key = app_store_connect_api_key(
      key_id: ENV['ASC_API_ID'],
      issuer_id: ENV['ASC_ISSUER_ID'],
      key_content: ENV['ASC_API_KEY'],
      duration: 1200, # optional (maximum 1200)
      in_house: false # optional but may be required if using match/sigh
    )
    # increment_version_number(
    #   version_number: ENV['VERSION_NUMBER'],
    #   xcodeproj: "./Django Files.xcodeproj"
    # )
    # Extract base version number without any -123 style additions
    base_version = ENV['VERSION_NUMBER'].split('-').first
    sh("sed -i '' 's/MARKETING_VERSION = [0-9]*\.[0-9]*\.[0-9]*/MARKETING_VERSION = #{base_version};/' \"../Django Files.xcodeproj/project.pbxproj\"")
    increment_build_number(
      build_number: ENV['BUILD_NUMBER'],
      xcodeproj: "./Django Files.xcodeproj"
    )
    build_app(
      clean: true
    )
    upload_to_app_store(
      skip_metadata: true,
      skip_screenshots: true,
      api_key: api_key,
      precheck_include_in_app_purchases: false
    )
  end


  lane :screenshots do
    setup_ci if ENV['CI']
    device = ENV['SNAPSHOT_DEVICE']

    # xcodebuild forwards env vars whose names start with TEST_RUNNER_ to the
    # test runner process, with the prefix stripped. Translate our public
    # SCREENSHOT_* vars into TEST_RUNNER_SCREENSHOT_* so the UI test bundle's
    # ProcessInfo.processInfo.environment sees them as SCREENSHOT_*.
    %w[SCREENSHOT_SERVER_URL SCREENSHOT_USERNAME SCREENSHOT_PASSWORD].each do |name|
      ENV["TEST_RUNNER_#{name}"] = ENV[name].to_s
    end

    params = {
      scheme: "Django Files",
      output_directory: "./fastlane/screenshots",
      override_status_bar: true,
      concurrent_simulators: false,
      only_testing: "Django FilesUITests/ScreenshotTests"
    }
    params[:devices] = [device] unless device.nil? || device.empty?

    capture_ios_screenshots(params)
  end

  lane :upload_screenshots do
    key_content = ENV['ASC_API_KEY'].to_s
    api_key = app_store_connect_api_key(
      key_id: ENV['ASC_API_ID'],
      issuer_id: ENV['ASC_ISSUER_ID'],
      key_content: key_content,
      is_key_content_base64: !key_content.strip.start_with?('-----'),
      duration: 1200,
      in_house: false
    )
    upload_to_app_store(
      app_identifier: "com.djangofiles.app",
      skip_binary_upload: true,
      skip_metadata: true,
      skip_screenshots: false,
      api_key: api_key,
      # Wipe any existing screenshots on the in-prep version before uploading.
      overwrite_screenshots: true,
      # Skip the interactive "review HTML report in browser" confirmation —
      # the CI environment can't act on it and we open the screenshots
      # locally after each run anyway.
      force: true,
      run_precheck_before_submit: false,
      precheck_include_in_app_purchases: false
    )

  end

  lane :tests do
    scan(
      destination: "platform=iOS Simulator,name=iPhone 17,OS=26.5",
      number_of_retries: 1,
      xcargs: "-maximum-parallel-testing-workers 1",
      skip_testing: "Django FilesUITests/ScreenshotTests"
    )
  end

  lane :ci do
    api_key = app_store_connect_api_key(
      key_id: ENV['ASC_API_ID'],
      issuer_id: ENV['ASC_ISSUER_ID'],
      key_content: ENV['ASC_API_KEY'],
      duration: 1200, # optional (maximum 1200)
      in_house: false # optional but may be required if using match/sigh
    )
    increment_version_number(
      version_number: '0.1',
      xcodeproj: "./Django Files.xcodeproj"
    )
    increment_build_number(
      build_number: ENV['BUILD_NUMBER'],
      xcodeproj: "./Django Files.xcodeproj"
    )
    build_app()
  end
end
